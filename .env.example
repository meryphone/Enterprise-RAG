# --- Entorno ---
ENV=local                          # local | production

# --- LLM y Embeddings ---
LLM_MODEL=gpt-4o
OPENAI_API_KEY=your_key_here
EMBEDDING_MODEL=text-embedding-3-large
ENABLE_VISION=0                    # 1 = describe imágenes y tablas degradadas con GPT-4o vision

# --- Chunking ---
CHILD_CHUNK_TOKENS=128             # tamaño del chunk hijo (retrieval)
PARENT_CHUNK_TOKENS=1024           # tamaño del chunk padre (contexto al LLM)

# --- Reranker ---
COHERE_API_KEY=your_key_here
COHERE_RERANK_MODEL=rerank-multilingual-v3.0

# --- Vector Store ---
CHROMA_API_KEY=your_key_here
CHROMA_TENANT=your_tenant_uuid
CHROMA_DATABASE=your_database_name  # visible en el panel de ChromaDB Cloud

# --- Retrieval ---
RETRIEVAL_TOP_K=30                 # candidatos tras fusión híbrida
RETRIEVAL_TOP_N=5                  # resultados finales tras rerank de Cohere
RETRIEVAL_PESO_VECTOR=0.5          # peso del score vectorial en la fusión (0–1)
RETRIEVAL_PESO_BM25=0.5            # peso del score BM25 en la fusión (0–1)

# --- Seguridad y Sesiones ---
AUTH_SECRET=your_random_32byte_hex  # genera con: python3 -c "import secrets; print(secrets.token_hex(32))"

# --- Redes ---
CLOUDFLARE_ORIGIN=                 # ej. https://miapp.trycloudflare.com

# --- Seed de usuarios (backend/.env.seed, nunca commitear) ---
# SEED_EMAIL_1=usuario@empresa.com
# SEED_NAME_1=Nombre Apellido
# SEED_ROLE_1=user
# SEED_PWD_1=contraseña_segura
# (repetir para _2, _3, _4)
